{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "AZURE_OPENAI_ENDPOINT": "https://true-crew-resource.openai.azure.com",
    "AZURE_AI_RESOURCE_ENDPOINT": "https://true-crew-resource.services.ai.azure.com"
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
