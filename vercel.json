{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "AZURE_OPENAI_ENDPOINT": "https://true-crew-resource.openai.azure.com",
    "AZURE_AI_RESOURCE_ENDPOINT": "https://true-crew-resource.services.ai.azure.com"
  },
  "rewrites": [
    { "source": "/api/research/project-summary-handoff", "destination": "/api/research/dispatch?kind=project-summary-handoff" },
    { "source": "/api/research/monitor-incident-postmortem", "destination": "/api/research/dispatch?kind=monitor-incident-postmortem" },
    { "source": "/api/tasks/:id/artifacts", "destination": "/api/tasks/:id?view=artifacts" },
    { "source": "/api/obsidian/project-note", "destination": "/api/chief/approvals?view=obsidian-project-note" },
    { "source": "/api/github/pull-requests", "destination": "/api/chief/approvals?view=github-pull-requests" },
    { "source": "/api/github/pr-comment", "destination": "/api/chief/approvals?view=github-pr-comment" },
    { "source": "/api/chief/approval-activity", "destination": "/api/chief/approvals?view=activity" },
    { "source": "/api/chief/operational-readiness", "destination": "/api/chief/approvals?view=operational-readiness" },
    { "source": "/api/chief/governed-slack-notify", "destination": "/api/chief/approvals?view=slack-notify" },
    { "source": "/api/chief/daily-turnover", "destination": "/api/chief/approvals?view=daily-turnover" },
    { "source": "/api/dev/governed-slack-test", "destination": "/api/chief/approvals?view=slack-test" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
