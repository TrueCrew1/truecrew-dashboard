# Research tool provider keys — LOCAL-ONLY TEMPLATE, not app config.
#
# This is separate from the app's `.env.example` at the repo root. Nothing in this
# file is read by the dashboard app or by any Chief-system agent — it's for David's
# own local research scripts/tools only. See `docs/RESEARCH_TOOL_SETUP.md` for the
# manual-vs-agent-usable distinction: adding a key here does NOT authorize any agent
# to use that provider.
#
# To use:
#   1. Copy this file to a local file matching this repo's `*.local` .gitignore
#      pattern, e.g. `docs/research-tools.env.local`.
#   2. Fill in real keys in that local copy only.
#   3. Never commit the local copy, never paste a real key back into this file, and
#      never paste one into any other tracked file (docs, TOOL_CATALOG, code, etc.).
#
# All values below are placeholders — dummy names only, no real secrets.

# Perplexity (research API — separate from the manual Perplexity Pro web chat)
PERPLEXITY_API_KEY=your-perplexity-api-key

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Kimi / Moonshot AI (developer API — separate from the manual kimi.com web chat)
KIMI_API_KEY=your-kimi-api-key

# DeepSeek (developer API — separate from the manual chat.deepseek.com web chat)
DEEPSEEK_API_KEY=your-deepseek-api-key

# GPT-5 mini (or other OpenAI-compatible model access, if separate from Azure above)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5-mini
