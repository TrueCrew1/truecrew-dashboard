# Supabase (server-side only — set in Vercel project settings)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub webhook (Vercel → Settings → Environment Variables)
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Internal API auth (required — all /api routes except the GitHub webhook)
# Server-side secret checked by lib/auth.ts. Generate: openssl rand -hex 32
INTERNAL_API_SECRET=your-internal-api-secret
# Client copy of the same value, sent as the x-internal-key header.
# Must match INTERNAL_API_SECRET. Note: visible in the bundle — this gates
# the API, it is not a substitute for Vercel Deployment Protection.
VITE_INTERNAL_KEY=your-internal-api-secret

# Frontend (optional — enables live API reads instead of mock fallback)
VITE_USE_LIVE_API=true

# Public Supabase anon key (future client auth — not used in v1 API layer)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# TrueCrew workspace + Obsidian vault (Google Drive = source of truth)
# Local Mac paths — used by npm run workspace:* / obsidian:setup-vault (not Vercel)
# See docs/RESEARCH_CLEANUP_WORKFLOW.md
TRUECREW_WORKSPACE_PATH=/Users/truecrew/Google Drive/TrueCrew
OBSIDIAN_VAULT_PATH=/Users/truecrew/Google Drive/TrueCrew/Obsidian Vaults/TrueCrew Second Brain

# Librarian agent (optional Tier 1 refinement — local Ollama)
LIBRARIAN_AI_ENABLED=false
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# LLM Router (Chief / Research / Builder lanes + POST /api/llm/suggest-tests)
#
# Copy this file to .env.local for local dev:
#   cp .env.example .env.local
#
# The router uses Azure only (all tiers). Legacy direct-API keys below are unused.
#
# Required for all router models (DeepSeek-V3.2, Kimi-K2.6, gpt-5-mini):
AZURE_OPENAI_API_KEY=
# Azure AI Foundry resource endpoint — no /api/projects/... or /openai/v1 suffix
AZURE_AI_RESOURCE_ENDPOINT=

# Legacy — not used by the current router:
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini

# Legacy — not used by the current router (kept for reference only):
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
