# Supabase (server-side only — set in Vercel project settings)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub webhook (Vercel → Settings → Environment Variables)
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Internal API auth (required — all /api routes except the GitHub webhook)
# Server-side secret checked by lib/auth.ts. Generate: openssl rand -hex 32
INTERNAL_API_SECRET=your-internal-api-secret
# Client copy of the same value, sent as the x-internal-key header.
# Must match INTERNAL_API_SECRET. Note: visible in the bundle — this gates
# the API, it is not a substitute for Vercel Deployment Protection.
VITE_INTERNAL_KEY=your-internal-api-secret

# Frontend (optional — enables live API reads instead of mock fallback)
VITE_USE_LIVE_API=true

# Public Supabase anon key (future client auth — not used in v1 API layer)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Obsidian vault (local dev only — not used on Vercel production)
OBSIDIAN_VAULT_PATH=/Users/truecrew/Library/Mobile Documents/iCloud~md~obsidian/Documents/TRUE CREW-SECOND BRAIN

# Librarian agent (optional Tier 1 refinement — local Ollama)
LIBRARIAN_AI_ENABLED=false
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# --- Chief AI fallback (server-side, all optional, all default OFF) ---
# Chief is deterministic-first: resolveChiefCommand() always runs first and
# its result is used as-is for every query it can specifically answer. This
# whole section only affects the catch-all "no specialist match" case.
#
# Precedence, checked in this order — see lib/chief-ai/router.ts:
#   1. CHIEF_AI_FALLBACK_ENABLED != "true"  -> deterministic only, nothing
#      below is ever read or called.
#   2. CHIEF_AI_LOCAL_ONLY_MODE == "true"   -> skip the whole Azure tier,
#      Ollama only (llama3, then deepseek-r1).
#   3. Otherwise: Azure GPT-5 mini -> Azure DeepSeek V4 Pro -> Azure Kimi
#      K2.6 -> Ollama llama3 -> Ollama deepseek-r1 -> canned fallback.
# A provider missing its required config below is skipped, not an error; a
# provider that errors (timeout, bad response) is logged and skipped too —
# the chain always resolves to something, it never throws.
CHIEF_AI_FALLBACK_ENABLED=false
CHIEF_AI_LOCAL_ONLY_MODE=false

# Azure AI Foundry (or Azure OpenAI-compatible) endpoint shared by every
# Azure model below. Each model is only attempted if endpoint + key + its
# own deployment name are all set.
AZURE_AI_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_AI_API_KEY=your-azure-ai-api-key
AZURE_GPT5_MINI_DEPLOYMENT=gpt-5-mini
AZURE_DEEPSEEK_V4_PRO_DEPLOYMENT=deepseek-v4-pro
AZURE_KIMI_K26_DEPLOYMENT=kimi-k2.6

# Local Ollama models Chief falls back to (shares OLLAMA_HOST above).
OLLAMA_CHIEF_MODEL_PRIMARY=llama3
OLLAMA_CHIEF_MODEL_SECONDARY=deepseek-r1

# --- Chief AI UI (browser-visible, default OFF) ---
# Purely a cosmetic gate — controls whether the "Ask AI" route badge renders
# at all. NOT a security boundary: the server always re-checks
# CHIEF_AI_FALLBACK_ENABLED independently of anything the client sends.
VITE_CHIEF_AI_UI_ENABLED=false
