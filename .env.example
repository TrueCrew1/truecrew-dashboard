# Supabase (server-side only — set in Vercel project settings)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub webhook (Vercel → Settings → Environment Variables)
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Internal API auth (required — all /api routes except the GitHub webhook)
# Server-side secret checked by lib/auth.ts. Generate: openssl rand -hex 32
INTERNAL_API_SECRET=your-internal-api-secret
# Client copy of the same value, sent as the x-internal-key header.
# Must match INTERNAL_API_SECRET. Note: visible in the bundle — this gates
# the API, it is not a substitute for Vercel Deployment Protection.
VITE_INTERNAL_KEY=your-internal-api-secret

# Today work orders — v1 single-org scope (server-side only)
TODAY_ORG_ID=your-org-id
TODAY_ORG_NAME=Your Field Services Org
# Optional — default Supervisor / active when unset
TODAY_MEMBERSHIP_ROLE=Supervisor
TODAY_MEMBERSHIP_STATUS=active

# Frontend (optional — enables live API reads instead of mock fallback)
VITE_USE_LIVE_API=true

# Public Supabase anon key (future client auth — not used in v1 API layer)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# PostHog — product analytics (client bundle; VITE_ prefix required)
# Production/preview only — both vars required; not sent in local dev, test, or vitest
# Setup + verification: docs/OBSERVABILITY.md
VITE_POSTHOG_API_KEY=phc_your_project_api_key
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — error tracking (production/preview only; omit DSN to disable)
# Setup + verification: docs/OBSERVABILITY.md
# SENTRY_DSN: server-side Today API route (tags route=today_work_orders, org_id=TODAY_ORG_ID)
SENTRY_DSN=https://your-key@o000000.ingest.us.sentry.io/0000000
# VITE_SENTRY_DSN: React SPA (tags route=today_work_orders while on Today page)
VITE_SENTRY_DSN=https://your-key@o000000.ingest.us.sentry.io/0000000

# Obsidian vault (local dev only — not used on Vercel production)
OBSIDIAN_VAULT_PATH=/Users/truecrew/Library/Mobile Documents/iCloud~md~obsidian/Documents/TRUE CREW-SECOND BRAIN
