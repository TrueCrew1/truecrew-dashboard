# Supabase (server-side only — set in Vercel project settings)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub webhook (Vercel → Settings → Environment Variables)
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Internal API auth (required — all /api routes except the GitHub webhook)
# Server-side secret checked by lib/auth.ts. Generate: openssl rand -hex 32
INTERNAL_API_SECRET=your-internal-api-secret
# Client copy of the same value, sent as the x-internal-key header.
# Must match INTERNAL_API_SECRET. Note: visible in the bundle — this gates
# the API, it is not a substitute for Vercel Deployment Protection.
VITE_INTERNAL_KEY=your-internal-api-secret

# Frontend (optional — enables live API reads instead of mock fallback)
VITE_USE_LIVE_API=true

# Public Supabase anon key (future client auth — not used in v1 API layer)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Obsidian vault (local dev only — not used on Vercel production)
# Knowledge Architecture V1 — see docs/FILE_SECOND_BRAIN_KNOWLEDGE_ARCHITECTURE_V1.md
OBSIDIAN_VAULT_PATH=/Users/truecrew/ObsidianVault
# Legacy vault (deprecated, kept for reference only — do not point OBSIDIAN_VAULT_PATH here):
# /Users/truecrew/Library/Mobile Documents/iCloud~md~obsidian/Documents/TRUE CREW-SECOND BRAIN

# Librarian agent (optional Tier 1 refinement — local Ollama)
LIBRARIAN_AI_ENABLED=false
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Chief AI fallback (optional — only used when resolveChiefCommand finds no
# specialist match, via lib/chief/modelRouter.ts). Deterministic answers
# always win; this only ever fires on the generic no-match branch.
#
# Cloud tier — Azure AI Foundry, key-based auth (server-side only). Model
# choice is automatic by query category (general -> gpt-5-mini, code/refactor
# -> kimi-k2-6, reasoning/strategy -> deepseek-v4-pro) — no manual override var.
# Azure is the intended primary sustained-execution lane while Azure Startup
# credits are active — see docs/AGENT_RUNBOOK.md § Chief AI Fallback Routing
# for post-credit fallback behavior once they expire.
CHIEF_AI_FALLBACK_ENABLED=false
AZURE_AI_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1
AZURE_AI_KEY=your-azure-ai-key
AZURE_AI_DEPLOYMENT_DEEPSEEK_V4_PRO=DeepSeek-V4-Pro
AZURE_AI_DEPLOYMENT_GPT5_MINI=gpt-5-mini
AZURE_AI_DEPLOYMENT_KIMI_K2_6=Kimi-K2.6
# Client copy — must match CHIEF_AI_FALLBACK_ENABLED to show the frontend UI.
VITE_CHIEF_AI_FALLBACK_ENABLED=false

# Local tier — same local Ollama instance as the Librarian agent above
# (OLLAMA_HOST), tried after an Azure failure, or exclusively when local-only
# mode is on. Not reachable from a deployed Vercel function — local dev only.
CHIEF_OLLAMA_FALLBACK_ENABLED=false
OLLAMA_MODEL_LLAMA3=llama3
OLLAMA_MODEL_DEEPSEEK_R1=deepseek-r1
# Forces Ollama-only routing (skips Azure entirely), server-side default.
CHIEF_LOCAL_ONLY_MODE=false
# Client copy — default state of the Chief panel's "Prefer local only" toggle.
VITE_CHIEF_LOCAL_ONLY_MODE=false

# Chief voice v1 — client-side only, no server-side keys needed. Speech
# input/output today runs entirely in the browser (Web Speech API +
# SpeechSynthesis, src/components/chief/useChiefVoice.ts) — nothing to set here.
# Server-side voice (api/chief/transcribe.ts, api/chief/speak.ts) is a scaffold
# only — both routes always return 501, and no transcription/TTS vendor has been
# chosen yet ("not scoped/decided" per those files' own TODOs and
# docs/AGENT_RUNBOOK.md § Voice Prep). No placeholder vendor keys are added here
# until a vendor is actually picked — see docs/AGENT_CAPABILITIES_SUMMARY.md.
