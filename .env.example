# Supabase (server-side only — set in Vercel project settings)
# Project ref = subdomain of SUPABASE_URL (e.g. fmomafwhcuothygmuiwa for https://fmomafwhcuothygmuiwa.supabase.co)
# Use the True Crew Command Center project — NOT the M&S Painting Supabase project.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub webhook (Vercel → Settings → Environment Variables)
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Frontend (optional — enables live API reads instead of mock fallback)
VITE_USE_LIVE_API=true

# Public Supabase anon key (future client auth — not used in v1 API layer)
# Must match the same project as SUPABASE_URL above.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# GitHub Actions only (not needed in Vercel or .env.local for app runtime):
# SUPABASE_ACCESS_TOKEN=...
# SUPABASE_PROJECT_REF=your-project-ref   # ref only, NOT the full URL
