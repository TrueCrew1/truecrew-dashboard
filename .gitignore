# Supabase CLI local link/cache state (regenerated by `supabase link` / CLI
# commands) — not secrets by themselves, but reveals real project/org IDs and
# has no reason to be version controlled.
supabase/.temp/
supabase/.branches/

# Vercel CLI local link state — projectId/orgId, not meant to be committed
# (the .vercel/README.txt boilerplate says so too).
.vercel/project.json
